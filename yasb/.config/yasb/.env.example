# yasb secrets
# copy this file to `.env` in ~/.config/yasb and fill in real values.
# `.env` is gitignored and loaded automatically by yasb on startup.
#
# IMPORTANT: values must be UNQUOTED and the names EXACT (case-sensitive) —
# yasb keeps surrounding quotes as part of the value, so KEY="abc" is sent
# literally as "abc" and fails. Correct:  YASB_WEATHER_API_KEY=abc123
YASB_WEATHER_API_KEY=your_weatherapi_key_here
YASB_GITHUB_TOKEN=your_github_token_here
